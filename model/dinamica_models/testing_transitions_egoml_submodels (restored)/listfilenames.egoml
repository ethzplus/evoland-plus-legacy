<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<script>
    <property key="dff.charset" value="UTF-8" />
    <property key="dff.date" value="2023-Jul-17 17:53:43" />
    <property key="dff.version" value="7.2.0.20221230" />
    <property key="metadata.author" value="Hermann Rodrigues" />
    <property key="metadata.organization" value="CSR / UFMG" />
    <property key="submodel.description" value='List the filenames in the given folder (and maybe its sub-folders) that match the given file pattern. The resulting filenames include their corresponding file paths.&#x0A;The functionality provided by this submodel is similar to the one provided by the &quot;List Filenames In Folder&quot; submodel, except that this implementation used Python internally. However, this version is simpler to use.' />
    <property key="submodel.group" value="Files" />
    <property key="submodel.largeicon" value="" />
    <property key="submodel.name" value="ListFilenames" />
    <property key="submodel.smallicon" value="" />
    <functor name="String">
        <property key="dff.functor.alias" value="File Pattern" />
        <property key="dff.functor.comment" value="Pattern of file names that will be returned. The pattern can include all wildcards supported by the OS shell. Ex: *.*, *.csv, my_image[0-9].tif, etc" />
        <property key="submodel.in.constant.advanced" value="no" />
        <property key="submodel.in.constant.description" value="Pattern of file names that will be returned. The pattern can include all wildcards supported by the OS shell. Ex: *.*, *.csv, my_image[0-9].tif, etc" />
        <property key="submodel.in.constant.name" value="filePattern" />
        <property key="submodel.in.constant.optional" value="no" />
        <property key="submodel.in.constant.order" value="2" />
        <outputport name="object" id="v1" />
    </functor>
    <functor name="BooleanValue">
        <property key="dff.functor.alias" value="Search Sub Folders Recursively" />
        <property key="dff.functor.comment" value="If true, also search for files in the sub-folders of the given folder recursively. Otherwise, the result only includes files from the given folder." />
        <property key="submodel.in.constant.advanced" value="yes" />
        <property key="submodel.in.constant.description" value="If true, also search for files in the sub-folders of the given folder recursively. Otherwise, the result only includes files from the given folder." />
        <property key="submodel.in.constant.name" value="searchSubFoldersRecursively" />
        <property key="submodel.in.constant.optional" value="yes" />
        <property key="submodel.in.constant.order" value="3" />
        <inputport name="constant">.no</inputport>
        <outputport name="object" id="v2" />
    </functor>
    <functor name="Folder">
        <property key="dff.functor.alias" value="Folder" />
        <property key="dff.functor.comment" value="Folder where the files are located." />
        <property key="submodel.in.constant.advanced" value="no" />
        <property key="submodel.in.constant.description" value="Folder where the files are located." />
        <property key="submodel.in.constant.name" value="folder" />
        <property key="submodel.in.constant.optional" value="no" />
        <property key="submodel.in.constant.order" value="1" />
        <outputport name="object" id="v3" />
    </functor>
    <functor name="ExtractStructTable">
        <property key="dff.functor.alias" value="extractStructTable572" />
        <property key="submodel.out.table.description" value="The list of filename (and their corresponding paths) found in the given folder that match the given extension." />
        <property key="submodel.out.table.name" value="files" />
        <property key="submodel.out.table.order" value="1" />
        <inputport name="struct" peerid="v4" />
        <inputport name="name">$&quot;(files)&quot;</inputport>
    </functor>
    <containerfunctor name="CalculatePythonExpression">
        <property key="dff.container.collapsed" value="yes" />
        <property key="dff.functor.alias" value="calculatePythonExpression13799" />
        <inputport name="expression">&quot;&quot;</inputport>
        <outputport name="result" id="v4" />
        <functor name="NumberString">
            <property key="dff.functor.alias" value="numberString569" />
            <inputport name="value" peerid="v3" />
            <inputport name="valueNumber">1</inputport>
        </functor>
        <functor name="NumberString">
            <property key="dff.functor.alias" value="numberString570" />
            <inputport name="value" peerid="v1" />
            <inputport name="valueNumber">2</inputport>
        </functor>
        <functor name="NumberValue">
            <property key="dff.functor.alias" value="numberValue571" />
            <inputport name="value" peerid="v2" />
            <inputport name="valueNumber">1</inputport>
        </functor>
    </containerfunctor>
</script>
