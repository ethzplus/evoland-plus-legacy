                        <functor name="NumberTable">
                            <property key="dff.functor.alias" value="Send table of simulation time steps" />
                            <inputport name="table" peerid="v15" />
                            <inputport name="tableNumber">1</inputport>
                        </functor>
                    </containerfunctor>
                    <containerfunctor name="IfThen">
                        <property key="dff.functor.alias" value="ifThen984" />
                        <inputport name="condition" peerid="v38" />
                        <inputport name="sequenceInput">.none</inputport>
                        <functor name="LoadCategoricalMap">
                            <property key="dff.functor.alias" value="Load Observed Lulc Map For Final Year Of Simulation" />
                            <inputport name="filename" peerid="v42" />
                            <inputport name="nullValue">.none</inputport>
                            <inputport name="storageMode">.default</inputport>
                            <inputport name="suffixDigits">0</inputport>
                            <inputport name="step" peerid="v5" />
                            <inputport name="workdir" peerid="v7" />
                            <outputport name="map" id="v44" />
                        </functor>
                        <functor name="LoadCategoricalMap">
                            <property key="dff.functor.alias" value="Load Simulated Lulc Map" />
                            <inputport name="filename" peerid="v41" />
                            <inputport name="nullValue">.none</inputport>
                            <inputport name="storageMode">.default</inputport>
                            <inputport name="suffixDigits">0</inputport>
                            <inputport name="step" peerid="v5" />
                            <inputport name="workdir" peerid="v7" />
                            <outputport name="map" id="v45" />
                        </functor>
                        <functor name="LoadCategoricalMap">
                            <property key="dff.functor.alias" value="Load Initial Lulc Map" />
                            <inputport name="filename" peerid="v9" />
                            <inputport name="nullValue">.none</inputport>
                            <inputport name="storageMode">.default</inputport>
                            <inputport name="suffixDigits">0</inputport>
                            <inputport name="step" peerid="v5" />
                            <inputport name="workdir" peerid="v7" />
                            <outputport name="map" id="v46" />
                        </functor>
                        <functor name="CalcSimilarityOfDifferences">
                            <property key="dff.functor.alias" value="calcSimilarityOfDifferences1017" />
                            <property key="viewer.similarity" value="yes" />
                            <property key="viewer.similarityMap" value="yes" />
                            <inputport name="initialMap" peerid="v46" />
                            <inputport name="observedMap" peerid="v44" />
                            <inputport name="simulatedMap" peerid="v45" />
                            <inputport name="useExponentialDecay">.yes</inputport>
                            <inputport name="windowSize">11</inputport>
                            <inputport name="printSimilarities">.yes</inputport>
                            <inputport name="exponentialDecayDivisor">2</inputport>
                            <outputport name="similarityMap" id="v47" />
                            <outputport name="similarity" id="v48" />
                        </functor>
                        <functor name="SaveTextFile">
                            <property key="dff.functor.alias" value="saveTextFile1018" />
                            <inputport name="text" peerid="v48" />
                            <inputport name="filename" peerid="v40" />
                            <inputport name="suffixDigits">2</inputport>
                            <inputport name="step" peerid="v5" />
                            <inputport name="workdir" peerid="v7" />
                        </functor>
                        <functor name="SaveMap">
                            <property key="dff.functor.alias" value="saveMap1019" />
                            <inputport name="map" peerid="v47" />
                            <inputport name="filename" peerid="v39" />
                            <inputport name="suffixDigits">2</inputport>
                            <inputport name="step" peerid="v5" />
                            <inputport name="useCompression">.yes</inputport>
                            <inputport name="workdir" peerid="v7" />
                            <inputport name="ignoreCostlySparseCategories">.yes</inputport>
                        </functor>
                    </containerfunctor>
                </containerfunctor>
            </containerfunctor>
            <containerfunctor name="Group">
                <property key="dff.functor.alias" value="Update control table to reflect simulation complete" />
                <inputport name="sequenceInput">.none</inputport>
                <containerfunctor name="CalculateRExpression">
                    <property key="dff.container.collapsed" value="no" />
                    <property key="dff.functor.alias" value="calculateRExpression1021" />
                    <inputport name="expression">&quot;&quot;</inputport>
                    <inputport name="treatWarningAsErrors">.no</inputport>
                    <functor name="NumberString">
                        <property key="dff.functor.alias" value="File path for control table" />
                        <inputport name="value" peerid="v1" />
                        <inputport name="valueNumber">1</inputport>
                    </functor>
                    <functor name="NumberString">
                        <property key="dff.functor.alias" value="Completion boolean" />
                        <inputport name="value" peerid="v8" />
                        <inputport name="valueNumber">2</inputport>
                    </functor>
                    <functor name="NumberValue">
                        <property key="dff.functor.alias" value="Simulation number" />
                        <inputport name="value" peerid="v6" />
                        <inputport name="valueNumber">1</inputport>
                    </functor>
                </containerfunctor>
            </containerfunctor>
        </containerfunctor>
    </containerfunctor>
</script>
