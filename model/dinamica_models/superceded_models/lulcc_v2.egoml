            <property key="viewer.string" value="yes" />
            <inputport name="tag">$&quot;(sim_lulc_folder_path)&quot;</inputport>
            <outputport name="string" id="v18" />
        </functor>
        <functor name="ReceiveString">
            <property key="dff.functor.alias" value="Receive model mode setting" />
